# DeepSeek 官方 API Key (主用)
# 申请: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-key-here

# 硅基流动 API Key (备用)
# 申请: https://siliconflow.cn
SILICONFLOW_API_KEY=sk-your-backup-key-here

# 飞书自定义机器人 Webhook
# 群设置 -> 群机器人 -> 添加机器人 -> 自定义机器人
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id

# 反馈接收端公网 HTTPS 地址
# 注意: 飞书卡片按钮要求 HTTPS; 如果这里填 http://,飞书会隐藏按钮
FEEDBACK_URL=https://your-domain.example.com/feedback

# 反馈链接签名密钥 (main.py 生成反馈按钮链接、feedback_server.py 校验签名都要用,两边必须一致)
# 自行生成一个随机字符串即可,例如: python -c "import secrets; print(secrets.token_hex(32))"
# 注意: 必须替换成真实随机值,占位符文本(含 "your_")会被 is_configured() 判定为未配置
FEEDBACK_SIGNING_SECRET=your_random_secret_here

# 汇率,卡片展示和利润计算共用
JPY_TO_CNY=0.045
